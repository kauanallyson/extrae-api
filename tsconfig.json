{
	"compilerOptions": {
		/* Language and Environment */
		"target": "ES2022",

		/* Modules (Bun) */
		"module": "Preserve",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["bun"],

		/* Interop Constraints */
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		/* Type Checking */
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true
	}
}
