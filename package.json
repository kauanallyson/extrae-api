{
	"name": "extrae-api",
	"version": "1.0.50",
	"scripts": {
		"test": "bun test",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "bun --env-file .env --bun drizzle-kit generate",
		"db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
		"db:push": "bun --bun drizzle-kit push",
		"db:pull": "bun --bun drizzle-kit pull",
		"db:studio": "bun --bun drizzle-kit studio",
		"lint": "bunx --bun @biomejs/biome check --write"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/openapi": "^1.4.14",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"elysia": "1.4.28",
		"exceljs": "^4.4.0",
		"openai": "^6.34.0",
		"pdfjs-dist": "^5.6.205",
		"pg": "^8.20.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/pdf-parse": "^1.1.5",
		"@types/pg": "^8.20.0",
		"bun-types": "latest",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.21.0"
	},
	"module": "src/index.js"
}
