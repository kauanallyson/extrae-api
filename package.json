{
	"name": "extrae-api",
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"start": "NODE_ENV=production bun run src/server.ts",
		"dev": "bun run --watch src/server.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"format": "biome format --write",
		"db:generate": "bunx --env-file=.env drizzle-kit generate",
		"db:migrate": "bunx --env-file=.env drizzle-kit migrate",
		"db:push": "bunx --env-file=.env drizzle-kit push",
		"db:pull": "bunx --env-file=.env drizzle-kit pull",
		"db:studio": "bunx --env-file=.env drizzle-kit studio"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/openapi": "^1.4.15",
		"cors": "^2.8.5",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"elysia": "^1.4.29",
		"exceljs": "^4.4.0",
		"express": "^4.21.2",
		"express-async-errors": "^3.1.1",
		"helmet": "^8.2.0",
		"multer": "^2.0.1",
		"openai": "^6.41.0",
		"pg": "^8.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@types/bun": "^1.3.14",
		"@types/cors": "^2.8.18",
		"@types/express": "^4.17.22",
		"@types/multer": "^1.4.12",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^6.0.3"
	}
}
